# ─────────────────────────────────────────────────────────────────────────────
# Le Caillou Magique — variables d'environnement
# Copiez ce fichier en `.env` et remplissez les valeurs.
# ─────────────────────────────────────────────────────────────────────────────

# Jeton du bot Discord.
# ⚠️ glyria.js IMPOSE le nom `TOKEN` (et non DISCORD_TOKEN). Il est chargé
# automatiquement depuis .env au démarrage.
TOKEN=

# Connexion PostgreSQL.
DATABASE_URL=postgres://caillou:caillou@localhost:5432/caillou

# ID du serveur Discord (guild) où le bot opère.
GUILD_ID=

# ── Perks de la boutique ──────────────────────────────────────────────────────
# Rôles à PRÉ-CRÉER dans Discord (positionnés SOUS le rôle le plus haut du bot,
# sinon le bot ne pourra pas les attribuer). On colle ici leurs IDs.
COLOR_ROLE_ID=
PRESTIGE_ROLE_ID=

# Salons que le perk "renommage" a le droit de toucher (IDs séparés par des virgules).
# Le bot ne renommera JAMAIS un salon hors de cette liste.
RENAME_WHITELIST=

# Statut par défaut du bot (restauré quand le perk "statut" expire).
DEFAULT_STATUS=rumine dans le vide cosmique

# ── Réglages de l'économie (optionnels — valeurs par défaut indiquées) ─────────
EARN_MIN=1
EARN_MAX=3
EARN_COOLDOWN_SECONDS=60
